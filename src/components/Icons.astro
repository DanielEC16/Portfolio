---
interface Props {
  name: string;
  imagen: string;
}

const { name, imagen } = Astro.props;
---

<div class="icon_container">
  <img src={imagen} alt="" />
  <span class="title-icon">{name}</span>
</div>

<style>
  .icon_container {
    width: 6.3rem;
    height: 6rem;
    text-align: center;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-direction: column;
    background: var(--jaguar-400);
    border-radius: 1.5rem;
  }
  img {
    width: 4rem;
  }
  span {
    color: var(--jaguar-100);
    font-size: 0.7rem;
    letter-spacing: .15rem;
  }
</style>
